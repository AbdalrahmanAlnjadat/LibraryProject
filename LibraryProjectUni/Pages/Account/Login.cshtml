@page
@model LibraryProjectUni.Pages.Account.LoginModel
@{
    Layout = "_LoginLayout";
    ViewData["Title"] = "Login";
}

<h2>Welcome Back</h2>
<p class="subtitle">Login to the Library System</p>

@if (!string.IsNullOrEmpty(Model.Error))
{
    <div class="alert alert-error">@Model.Error</div>
}

<form method="post">
    <div class="form-group">
        <label asp-for="Email" class="form-label"></label>
        <input asp-for="Email" type="email" class="form-input" placeholder="Enter your email" required />
    </div>

    <div class="form-group">
        <label asp-for="Password" class="form-label"></label>
        <input asp-for="Password" type="password" class="form-input" placeholder="Enter your password" required />
    </div>

    <button type="submit" class="btn btn-primary">Login</button>
</form>

<div class="link">
    Don't have an account? <a href="/Account/Register">Register</a>
</div>
