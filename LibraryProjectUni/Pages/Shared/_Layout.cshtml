<!DOCTYPE html>
<html lang="en">
<head>
    <title>@ViewData["Title"] - Library System</title>
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body class="app-shell">
    @{
        var roleId = Context.Session.GetInt32("RoleID") ?? 0;
        var isLibrarian = roleId == 1;
        var homeUrl = isLibrarian ? "/Librarian/Dashboard" : "/Member/Dashboard";
        var fullName = Context.Session.GetString("FullName") ?? "Guest";
        var currentPath = Context.Request.Path.Value ?? "";
    }

    <aside class="sidebar">
        <a href="@homeUrl" class="brand">
            <span class="brand-mark">L</span>
            <span>
                <strong>Library Stream</strong>
                <small>@(isLibrarian ? "Control Room" : "Member Library")</small>
            </span>
        </a>

        <nav class="nav-stack" aria-label="Primary navigation">
            @if (isLibrarian)
            {
                <a href="/Librarian/Dashboard" class="nav-link @(currentPath.StartsWith("/Librarian/Dashboard") ? "active" : "")">Dashboard</a>
                <a href="/Librarian/Books" class="nav-link @(currentPath.StartsWith("/Librarian/Books") || currentPath.StartsWith("/Librarian/AddBook") || currentPath.StartsWith("/Librarian/EditBook") ? "active" : "")">Catalog</a>
                <a href="/Librarian/Users" class="nav-link @(currentPath.StartsWith("/Librarian/Users") || currentPath.StartsWith("/Librarian/UserDetails") ? "active" : "")">Members</a>
                <a href="/Librarian/Borrows" class="nav-link @(currentPath.StartsWith("/Librarian/Borrows") ? "active" : "")">Borrows</a>
            }
            else
            {
                <a href="/Member/Dashboard" class="nav-link @(currentPath.StartsWith("/Member/Dashboard") ? "active" : "")">Home</a>
                <a href="/Member/Books" class="nav-link @(currentPath.StartsWith("/Member/Books") || currentPath.StartsWith("/Member/BookDetails") ? "active" : "")">Browse</a>
                <a href="/Member/History" class="nav-link @(currentPath.StartsWith("/Member/History") ? "active" : "")">History</a>
                <a href="/Member/Profile" class="nav-link @(currentPath.StartsWith("/Member/Profile") ? "active" : "")">Profile</a>
            }
        </nav>

        <form method="post" action="/Account/Logout" class="logout-form">
            @Html.AntiForgeryToken()
            <button type="submit" class="btn btn-danger btn-block">Logout</button>
        </form>
    </aside>

    <main class="main-panel">
        <header class="topbar">
            <div>
                <span class="eyebrow">Now managing</span>
                <h1>@(ViewData["Title"] ?? "Library")</h1>
            </div>
            <div class="user-chip">
                <span class="user-avatar">@fullName.Substring(0, 1).ToUpperInvariant()</span>
                <span>@fullName</span>
            </div>
        </header>

        <section class="content-stage">
            @RenderBody()
        </section>
    </main>
</body>
</html>
